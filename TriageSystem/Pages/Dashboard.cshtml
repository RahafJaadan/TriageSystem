@page
<meta http-equiv="refresh" content="3">
@model TriageSystem.Pages.DashboardModel

<h1 style="font-size:36px; font-weight:900; margin-bottom:10px;">
    Emergency Dashboard
</h1>
<div class="filter-bar">
    <a class="filter-btn @(Model.SelectedFilter == "today" ? "active" : "")" href="/Dashboard?filter=today">Today</a>
    <a class="filter-btn @(Model.SelectedFilter == "yesterday" ? "active" : "")" href="/Dashboard?filter=yesterday">Yesterday</a>
    <a class="filter-btn @(Model.SelectedFilter == "week" ? "active" : "")" href="/Dashboard?filter=week">Week</a>
    <a class="filter-btn @(Model.SelectedFilter == "month" ? "active" : "")" href="/Dashboard?filter=month">Month</a>
</div>

<div style="display:flex; gap:30px;">


    <div style="flex:1;">

    <div class="card danger">
        <h3>Level 1</h3>
        <p>@Model.Level1Count patients</p>
    </div>

    <div class="card warning">
        <h3>Level 2</h3>
        <p>@Model.Level2Count patients</p>
    </div>

    <div class="card medium">
        <h3>Level 3</h3>
        <p>@Model.Level3Count patients</p>
    </div>

    <div class="card normal">
        <h3>Level 4</h3>
        <p>@Model.Level4Count patients</p>
    </div>
<div class="card level5">
<h3>Level 5</h3>
<p>@Model.Level5Count patients</p>
</div>
    </div>

    <div style="width:280px;">
        <h3 style="text-align:center;">
            Total: @(Model.Level1Count + Model.Level2Count + Model.Level3Count + Model.Level4Count + Model.Level5Count) 
        </h3>
        <canvas id="triageChart"></canvas>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

        var ctx = document.getElementById('triageChart').getContext('2d');

        new Chart(ctx, {
        type: 'doughnut',
        data: {
        labels: ['Level 1', 'Level 2', 'Level 3', 'Level 4','Level 5' ],
        datasets: [{
        data: [
        @Model.Level1Count,
        @Model.Level2Count,
        @Model.Level3Count,
        @Model.Level4Count,
        @Model.Level5Count,
        ],
        backgroundColor: [
        '#e74c3c',
        '#e67e22',
        '#f1c40f',
        '#2ecc71',
        '#6c757d',
        ]
        }]
        }
        });

        });
    </script>

</div>

<style>
    .dashboard {
    display: flex;
    flex-direction: column;
    gap: 20px;
    }


    .card {
        padding: 10px;
        border-radius: 10px;
        color: white;
        text-align: center;
        font-size: 14px
    }
</style>
<style>
    .card {
        padding: 20px;
        border-radius: 12px;
        text-align: center;
        font-size: 18px;
    }

    
    .danger {
        background-color: #e74c3c;
        color: white;
    }

   
    .warning {
        background-color: #e67e22;
        color: white;
    }

    .medium {
        background-color: #f1c40f;
    color: white;
    }

    
    .normal {
        background-color: #2ecc71;
        color: white;
    }
  .level5 {
    background: #6c757d; 
color: white;
}
</style>



